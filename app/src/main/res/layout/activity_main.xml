<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0F">

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_gradient"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="80dp"
            android:paddingBottom="40dp"
            android:paddingLeft="24dp"
            android:paddingRight="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎬"
                android:textSize="72sp"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Video Widget"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Transition"
                android:textColor="#80FFFFFF"
                android:textSize="18sp"
                android:layout_marginBottom="48dp"/>

            <!-- بطاقة الحالة -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/glass_card">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="STATUS"
                    android:textColor="#80FFFFFF"
                    android:textSize="11sp"
                    android:letterSpacing="0.15"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/no_video"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:layout_marginBottom="8dp"/>

                <!-- Progress bar للمعالجة -->
                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:visibility="gone"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:max="100"/>

            </LinearLayout>

            <!-- بطاقة الفيديو -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/glass_card">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="VIDEO"
                    android:textColor="#80FFFFFF"
                    android:textSize="11sp"
                    android:letterSpacing="0.15"
                    android:layout_marginBottom="16dp"/>

                <Button
                    android:id="@+id/btnSelectVideo"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="@string/choose_video"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:background="@drawable/btn_glass"/>

            </LinearLayout>

            <!-- زر Reset -->
            <Button
                android:id="@+id/btnReset"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="@string/reset"
                android:textColor="#80FFFFFF"
                android:textSize="15sp"
                android:background="@drawable/btn_glass"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Frame 0 = Lock  •  Last Frame = Home"
                android:textColor="#40FFFFFF"
                android:textSize="12sp"/>

        </LinearLayout>
    </ScrollView>
</FrameLayout>
